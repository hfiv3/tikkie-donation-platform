# Server
PORT=3000
NODE_ENV=development

# Admin
ADMIN_SECRET=change-me-to-a-secure-secret

# Database (optional — defaults to ./data/donatieactie.db)
# DB_PATH=/app/data/donatieactie.db

# Tikkie API
# Modes: "stub" (test, geen echte betalingen) of "production" (echte Tikkie API)
TIKKIE_MODE=stub
TIKKIE_API_KEY=
TIKKIE_APP_TOKEN=
TIKKIE_SANDBOX=true

# URL waar de gebruiker naartoe gaat na betaling (optioneel)
# Voorbeeld: https://jouwdomein.nl/?bedankt
AFTER_PAYMENT_URL=

# Slack notificaties (incoming webhook URL)
# Maak een webhook aan via https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Frontend API URL
# Lokale ontwikkeling: http://localhost:3001
# Productie: "" (leeg, same-origin)
NEXT_PUBLIC_API_URL=http://localhost:3001
